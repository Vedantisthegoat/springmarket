<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spring Garden Market 🌱</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,700;0,900;1,300;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #faf6ef;
  --cream2: #f3ede0;
  --cream3: #e8dfc8;
  --brown: #5c3d1e;
  --brown2: #8a5c2e;
  --green: #2d5a27;
  --green2: #4a8c42;
  --green3: #7ab870;
  --green-light: #e8f5e4;
  --terracotta: #c4622d;
  --terra-light: #fce8dc;
  --gold: #c9920a;
  --gold-light: #fef3d0;
  --text: #2a1f0e;
  --text2: #6b5640;
  --text3: #a08060;
  --border: rgba(92,61,30,0.12);
  --border2: rgba(92,61,30,0.2);
  --shadow: 0 4px 24px rgba(44,31,10,0.1);
  --shadow2: 0 12px 48px rgba(44,31,10,0.15);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--cream); color: var(--text); min-height: 100vh; overflow-x: hidden; }

/* ── PAGES ── */
.page { display: none; min-height: 100vh; }
.page.active { display: block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
.page.active { animation: fadeIn 0.35s ease; }

/* ── SHARED BUTTONS ── */
.btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.3rem; border-radius: 100px; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 600; font-size: 0.875rem; cursor: pointer; border: none; transition: all 0.2s; text-decoration: none; }
.btn-green { background: var(--green); color: #fff; }
.btn-green:hover { background: var(--green2); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(45,90,39,0.3); }
.btn-terra { background: var(--terracotta); color: #fff; }
.btn-terra:hover { background: #d4713a; transform: translateY(-1px); }
.btn-outline { background: transparent; border: 1.5px solid var(--brown2); color: var(--brown); }
.btn-outline:hover { background: var(--cream2); }
.btn-ghost { background: transparent; color: var(--text2); }
.btn-ghost:hover { background: var(--cream2); }
.btn-sm { padding: 0.4rem 0.9rem; font-size: 0.78rem; }
.btn-lg { padding: 0.8rem 1.8rem; font-size: 1rem; border-radius: 100px; }
.btn-full { width: 100%; justify-content: center; border-radius: 12px; padding: 0.85rem; font-size: 0.95rem; }

/* ════════════════════════
   LANDING PAGE
════════════════════════ */
#page-landing { background: var(--cream); }

.landing-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 5vw; background: rgba(250,246,239,0.9);
  backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 100;
  border-bottom: 1px solid var(--border);
}
.site-logo { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 700; color: var(--green); display: flex; align-items: center; gap: 0.4rem; cursor: pointer; }
.site-logo .leaf { font-size: 1.3rem; }
.nav-links { display: flex; gap: 1.5rem; list-style: none; }
.nav-links a { text-decoration: none; color: var(--text2); font-size: 0.875rem; font-weight: 500; transition: color 0.2s; }
.nav-links a:hover { color: var(--green); }
.nav-actions { display: flex; gap: 0.6rem; align-items: center; }

/* HERO */
.hero {
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
  align-items: center; padding: 5rem 5vw 4rem; max-width: 1200px; margin: 0 auto;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: var(--green-light); color: var(--green); border-radius: 100px;
  padding: 0.35rem 1rem; font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 1.25rem;
}
.hero h1 {
  font-family: 'Fraunces', serif; font-size: clamp(2.8rem, 5vw, 4rem);
  font-weight: 900; line-height: 1.08; letter-spacing: -0.02em;
  color: var(--text); margin-bottom: 1.25rem;
}
.hero h1 em { font-style: italic; color: var(--green2); }
.hero-sub { color: var(--text2); font-size: 1.05rem; line-height: 1.75; margin-bottom: 2rem; font-weight: 400; max-width: 440px; }
.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.hero-stats { display: flex; gap: 2rem; padding-top: 2rem; border-top: 1px solid var(--border); }
.hstat-num { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 700; color: var(--green); display: block; }
.hstat-label { font-size: 0.78rem; color: var(--text3); font-weight: 500; }

.hero-visual { position: relative; }
.hero-card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.hero-plant-card {
  background: #fff; border-radius: 18px; overflow: hidden;
  box-shadow: var(--shadow); border: 1px solid var(--border);
  transition: transform 0.3s; cursor: pointer;
}
.hero-plant-card:hover { transform: translateY(-4px); box-shadow: var(--shadow2); }
.hpc-img { height: 130px; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; position: relative; overflow: hidden; }
.hpc-img-1 { background: linear-gradient(135deg, #d4edda, #a8d5a2); }
.hpc-img-2 { background: linear-gradient(135deg, #fde8d8, #f5c4a0); }
.hpc-img-3 { background: linear-gradient(135deg, #e8f4e8, #c5e0c3); }
.hpc-img-4 { background: linear-gradient(135deg, #fff3cd, #fde4a0); }
.hpc-body { padding: 0.85rem; }
.hpc-name { font-weight: 700; font-size: 0.82rem; margin-bottom: 0.2rem; }
.hpc-price { color: var(--terracotta); font-weight: 700; font-size: 0.82rem; }
.hpc-loc { color: var(--text3); font-size: 0.7rem; margin-top: 0.2rem; }
.hero-float-badge {
  position: absolute; bottom: -1rem; left: 50%; transform: translateX(-50%);
  background: #fff; border-radius: 100px; padding: 0.65rem 1.25rem;
  box-shadow: var(--shadow2); display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.8rem; font-weight: 600; white-space: nowrap; border: 1px solid var(--border);
}

/* FEATURES */
.section { padding: 5rem 5vw; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-label { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--terracotta); margin-bottom: 0.75rem; }
.section-label::before { content:''; width:16px; height:2px; background:var(--terracotta); border-radius:2px; }
h2.section-title { font-family: 'Fraunces', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 0.75rem; }
.section-desc { color: var(--text2); font-size: 1rem; line-height: 1.7; max-width: 500px; margin-bottom: 3rem; }

.features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
.feat-card { background: #fff; border-radius: 20px; padding: 2rem; border: 1px solid var(--border); transition: all 0.25s; }
.feat-card:hover { box-shadow: var(--shadow2); transform: translateY(-3px); }
.feat-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1rem; }
.fi-green { background: var(--green-light); }
.fi-terra { background: var(--terra-light); }
.fi-gold { background: var(--gold-light); }
.feat-card h3 { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.01em; }
.feat-card p { color: var(--text2); font-size: 0.85rem; line-height: 1.65; }

/* HOW IT WORKS */
.hiw-section { background: var(--green); color: #fff; padding: 5rem 5vw; }
.hiw-inner { max-width: 1100px; margin: 0 auto; }
.hiw-section .section-label { color: var(--green3); }
.hiw-section .section-label::before { background: var(--green3); }
.hiw-section h2 { color: #fff; margin-bottom: 3rem; }
.steps-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; }
.step { text-align: center; }
.step-num { font-family: 'Fraunces', serif; font-size: 2.5rem; font-weight: 900; color: var(--green3); margin-bottom: 0.75rem; opacity: 0.7; }
.step-icon { font-size: 2rem; margin-bottom: 0.75rem; }
.step h4 { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
.step p { font-size: 0.82rem; color: rgba(255,255,255,0.7); line-height: 1.6; }

/* LISTINGS PREVIEW */
.listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 1.25rem; }
.plant-card { background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid var(--border); cursor: pointer; transition: all 0.25s; }
.plant-card:hover { box-shadow: var(--shadow2); transform: translateY(-4px); }
.pc-img { height: 170px; display: flex; align-items: center; justify-content: center; font-size: 4rem; position: relative; }
.pc-img-1{background:linear-gradient(145deg,#c8e6c9,#81c784);}
.pc-img-2{background:linear-gradient(145deg,#fff9c4,#f9a825);}
.pc-img-3{background:linear-gradient(145deg,#ffccbc,#ff8a65);}
.pc-img-4{background:linear-gradient(145deg,#e1f5fe,#81d4fa);}
.pc-img-5{background:linear-gradient(145deg,#f3e5f5,#ce93d8);}
.pc-img-6{background:linear-gradient(145deg,#dcedc8,#aed581);}
.pc-badge { position: absolute; top: 0.75rem; left: 0.75rem; background: rgba(255,255,255,0.95); border-radius: 100px; padding: 0.2rem 0.65rem; font-size: 0.68rem; font-weight: 700; color: var(--green); }
.pc-trade { color: var(--terracotta); }
.pc-body { padding: 1rem; }
.pc-title { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.25rem; }
.pc-seller { font-size: 0.75rem; color: var(--text3); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.3rem; }
.pc-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 0.75rem; border-top: 1px solid var(--border); }
.pc-price { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.05rem; color: var(--terracotta); }
.pc-loc { font-size: 0.72rem; color: var(--text3); display: flex; align-items: center; gap: 0.2rem; }

/* CTA */
.cta-section { background: var(--cream2); padding: 5rem 5vw; text-align: center; }
.cta-inner { max-width: 600px; margin: 0 auto; }
.cta-inner h2 { font-family: 'Fraunces', serif; font-size: 2.5rem; font-weight: 900; margin-bottom: 1rem; letter-spacing: -0.02em; }
.cta-inner p { color: var(--text2); margin-bottom: 2rem; line-height: 1.7; }

/* FOOTER */
footer { background: var(--text); color: rgba(255,255,255,0.8); padding: 3rem 5vw; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
.footer-logo { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 700; color: #fff; }
.footer-links { display: flex; gap: 1.5rem; list-style: none; }
.footer-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.82rem; transition: color 0.2s; }
.footer-links a:hover { color: #fff; }
.footer-copy { font-size: 0.78rem; color: rgba(255,255,255,0.4); }

/* ════════════════════════
   AUTH PAGE
════════════════════════ */
#page-auth {
  background: var(--cream);
  display: none;
  min-height: 100vh;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}
#page-auth.active { display: flex; }

.auth-wrap { display: grid; grid-template-columns: 1fr 1fr; max-width: 900px; width: 100%; border-radius: 28px; overflow: hidden; box-shadow: 0 30px 80px rgba(44,31,10,0.2); }
.auth-left { background: var(--green); padding: 3rem; color: #fff; display: flex; flex-direction: column; justify-content: space-between; }
.auth-left-logo { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 700; margin-bottom: 2rem; }
.auth-left h2 { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 900; line-height: 1.2; margin-bottom: 1rem; letter-spacing: -0.02em; }
.auth-left p { font-size: 0.875rem; color: rgba(255,255,255,0.75); line-height: 1.7; }
.auth-perks { margin-top: 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
.auth-perk { display: flex; align-items: center; gap: 0.75rem; font-size: 0.85rem; color: rgba(255,255,255,0.9); }
.auth-perk-icon { width: 32px; height: 32px; background: rgba(255,255,255,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.auth-right { background: #fff; padding: 3rem; }
.auth-tabs { display: flex; background: var(--cream); border-radius: 12px; padding: 3px; margin-bottom: 2rem; }
.atab { flex: 1; text-align: center; padding: 0.6rem; border-radius: 10px; font-size: 0.875rem; font-weight: 600; cursor: pointer; color: var(--text2); transition: all 0.2s; user-select: none; }
.atab.active { background: #fff; color: var(--text); box-shadow: 0 2px 8px rgba(44,31,10,0.1); }
.auth-form-title { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 700; margin-bottom: 0.3rem; }
.auth-form-sub { color: var(--text2); font-size: 0.85rem; margin-bottom: 1.75rem; }
.fg { margin-bottom: 1rem; }
.fl { display: block; font-size: 0.78rem; font-weight: 700; color: var(--text2); margin-bottom: 0.4rem; letter-spacing: 0.03em; text-transform: uppercase; }
.fi { width: 100%; background: var(--cream); border: 1.5px solid var(--border2); border-radius: 10px; padding: 0.75rem 1rem; color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9rem; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
.fi::placeholder { color: var(--text3); }
.fi:focus { border-color: var(--green2); box-shadow: 0 0 0 3px rgba(74,140,66,0.12); }
.fi-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.err-msg { background: #fff0f0; border: 1px solid rgba(196,98,45,0.3); color: var(--terracotta); font-size: 0.8rem; padding: 0.6rem 0.9rem; border-radius: 8px; margin-bottom: 1rem; display: none; }
.forgot-link { font-size: 0.75rem; color: var(--text3); text-align: right; margin-top: 0.3rem; cursor: pointer; }
.forgot-link:hover { color: var(--green); }
.form-switch { text-align: center; margin-top: 1rem; font-size: 0.8rem; color: var(--text3); }
.form-switch a { color: var(--green); text-decoration: none; font-weight: 600; }
.demo-bar { display: flex; align-items: center; gap: 1rem; margin: 1rem 0; }
.demo-bar::before, .demo-bar::after { content:''; flex:1; height:1px; background:var(--border); }
.demo-bar span { font-size: 0.72rem; color: var(--text3); }

/* ════════════════════════
   APP SHELL
════════════════════════ */
#page-app { display: none; min-height: 100vh; flex-direction: column; }
#page-app.active { display: flex; }

.app-nav {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2rem; height: 62px; background: #fff;
  border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100;
  box-shadow: 0 2px 12px rgba(44,31,10,0.06);
}
.app-nav-center { display: flex; gap: 0.25rem; }
.anav-item { display: flex; align-items: center; gap: 0.45rem; padding: 0.5rem 0.9rem; border-radius: 100px; cursor: pointer; font-size: 0.85rem; font-weight: 600; color: var(--text2); transition: all 0.15s; user-select: none; white-space: nowrap; }
.anav-item:hover { background: var(--cream); color: var(--text); }
.anav-item.active { background: var(--green-light); color: var(--green); }
.anav-badge { background: var(--terracotta); color: #fff; font-size: 0.6rem; font-weight: 700; padding: 0.1rem 0.35rem; border-radius: 100px; margin-left: 0.1rem; }
.user-menu { display: flex; align-items: center; gap: 0.75rem; }
.user-av { width: 34px; height: 34px; border-radius: 50%; background: var(--green-light); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; cursor: pointer; border: 2px solid var(--green3); }
.user-name-nav { font-size: 0.82rem; font-weight: 600; color: var(--text2); }

/* VIEWS */
.view { display: none; flex: 1; }
.view.active { display: block; animation: fadeIn 0.25s ease; }

/* ─── MARKETPLACE VIEW ─── */
#view-market { background: var(--cream); }
.market-inner { max-width: 1200px; margin: 0 auto; padding: 2rem; }
.market-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem; }
.market-search { display: flex; align-items: center; gap: 0.6rem; background: #fff; border: 1.5px solid var(--border2); border-radius: 100px; padding: 0.6rem 1.1rem; width: 320px; transition: border-color 0.2s; }
.market-search:focus-within { border-color: var(--green2); }
.market-search input { background: transparent; border: none; outline: none; color: var(--text); font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.875rem; flex: 1; }
.market-search input::placeholder { color: var(--text3); }
.filter-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
.filter-chip { padding: 0.4rem 0.9rem; border-radius: 100px; font-size: 0.78rem; font-weight: 600; cursor: pointer; border: 1.5px solid var(--border2); color: var(--text2); background: #fff; transition: all 0.15s; user-select: none; }
.filter-chip:hover { border-color: var(--green2); color: var(--green); }
.filter-chip.active { background: var(--green); color: #fff; border-color: var(--green); }

/* LISTING DETAIL MODAL */
.modal-overlay { position: fixed; inset: 0; background: rgba(44,31,10,0.5); z-index: 500; display: none; align-items: center; justify-content: center; padding: 2rem; backdrop-filter: blur(4px); }
.modal-overlay.open { display: flex; animation: fadeIn 0.2s ease; }
.modal-box { background: #fff; border-radius: 24px; max-width: 660px; width: 100%; max-height: 90vh; overflow-y: auto; box-shadow: 0 30px 80px rgba(44,31,10,0.25); }
.modal-img { height: 220px; display: flex; align-items: center; justify-content: center; font-size: 5rem; border-radius: 24px 24px 0 0; }
.modal-body { padding: 2rem; }
.modal-title { font-family: 'Fraunces', serif; font-size: 1.6rem; font-weight: 700; margin-bottom: 0.4rem; }
.modal-price { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 700; color: var(--terracotta); margin-bottom: 0.5rem; }
.modal-meta { display: flex; gap: 1.25rem; flex-wrap: wrap; margin-bottom: 1rem; }
.modal-meta-item { display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; color: var(--text2); }
.modal-desc { color: var(--text2); font-size: 0.9rem; line-height: 1.75; margin-bottom: 1.5rem; }
.modal-seller { display: flex; align-items: center; gap: 0.75rem; padding: 1rem; background: var(--cream); border-radius: 14px; margin-bottom: 1.25rem; }
.seller-av { width: 44px; height: 44px; border-radius: 50%; background: var(--green-light); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; flex-shrink: 0; }
.seller-name { font-weight: 700; font-size: 0.9rem; }
.seller-loc { font-size: 0.78rem; color: var(--text3); }
.seller-rating { font-size: 0.78rem; color: var(--gold); margin-top: 0.15rem; }
.modal-actions { display: flex; gap: 0.75rem; }
.modal-close { position: absolute; top: 1rem; right: 1rem; width: 36px; height: 36px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1.1rem; transition: background 0.15s; }
.modal-close:hover { background: var(--cream2); }
.modal-wrapper { position: relative; }

/* ─── SELL VIEW ─── */
#view-sell { background: var(--cream); }
.sell-inner { max-width: 720px; margin: 0 auto; padding: 2rem; }
.sell-card { background: #fff; border-radius: 24px; border: 1px solid var(--border); padding: 2.5rem; box-shadow: var(--shadow); }
.sell-title { font-family: 'Fraunces', serif; font-size: 1.7rem; font-weight: 700; margin-bottom: 0.4rem; }
.sell-sub { color: var(--text2); font-size: 0.9rem; margin-bottom: 2rem; }
.upload-zone { border: 2px dashed var(--border2); border-radius: 16px; padding: 2.5rem; text-align: center; cursor: pointer; transition: all 0.2s; background: var(--cream); margin-bottom: 1.25rem; }
.upload-zone:hover { border-color: var(--green2); background: var(--green-light); }
.upload-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
.upload-text { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.25rem; }
.upload-hint { font-size: 0.78rem; color: var(--text3); }
.type-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.6rem; margin-bottom: 1.25rem; }
.type-opt { padding: 0.7rem; border-radius: 12px; border: 1.5px solid var(--border2); text-align: center; cursor: pointer; transition: all 0.15s; font-size: 0.8rem; font-weight: 600; color: var(--text2); background: var(--cream); user-select: none; }
.type-opt:hover { border-color: var(--green2); color: var(--green); }
.type-opt.selected { border-color: var(--green); background: var(--green-light); color: var(--green); }
.type-opt .t-icon { display: block; font-size: 1.4rem; margin-bottom: 0.3rem; }
