// ══════════════════════════════════
//  ROUTING
// ══════════════════════════════════
function goTo(page, extra) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const target = document.getElementById('page-' + page);
  if (target) target.classList.add('active');
  if (page === 'auth' && extra) switchAuth(extra);
  if (page === 'app') {
    renderMarket();
    renderCommunity();
    renderMessages();
    renderDashboard();
  }
  window.scrollTo(0,0);
}

function showView(name, navEl) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.anav-item').forEach(n => n.classList.remove('active'));
  const v = document.getElementById('view-' + name);
  if (v) v.classList.add('active');
  if (navEl) navEl.classList.add('active');
}

// ══════════════════════════════════
//  AUTH
// ══════════════════════════════════
function switchAuth(type) {
  document.getElementById('aform-signup').style.display = type === 'signup' ? 'block' : 'none';
  document.getElementById('aform-login').style.display = type === 'login' ? 'block' : 'none';
  document.getElementById('atab-signup').classList.toggle('active', type === 'signup');
  document.getElementById('atab-login').classList.toggle('active', type === 'login');
}

function doSignup() {
  const fn = document.getElementById('s-fname').value.trim();
  const ln = document.getElementById('s-lname').value.trim();
  const em = document.getElementById('s-email').value.trim();
  const loc = document.getElementById('s-location').value;
  const pw = document.getElementById('s-pass').value;
  const err = document.getElementById('signup-err');
  if (!fn || !ln || !em || !loc || !pw) { err.style.display = 'block'; return; }
  err.style.display = 'none';
  currentUser = { name: fn + ' ' + ln, firstName: fn, email: em, location: loc };
  enterApp();
}

function doLogin() {
  const em = document.getElementById('l-email').value.trim();
  const pw = document.getElementById('l-pass').value;
  const err = document.getElementById('login-err');
  if (!em || !pw) { err.style.display = 'block'; return; }
  err.style.display = 'none';
  currentUser = { name: 'Maria Garcia', firstName: 'Maria', email: em, location: 'South Bay' };
  enterApp();
}

function demoLogin() {
  currentUser = { name: 'Maria Garcia', firstName: 'Maria', email: 'maria@demo.com', location: 'South Bay (San Jose/Santa Clara)' };
  enterApp();
}

function enterApp() {
  document.getElementById('user-name-nav').textContent = currentUser.firstName + ' G.';
  document.getElementById('dash-greeting').textContent = `Welcome back, ${currentUser.firstName}! 🌿`;
  goTo('app');
  toast(`Welcome back, ${currentUser.firstName}! 🌱`);
}

function doLogout() {
  currentUser = null;
  goTo('landing');
  toast('Logged out. See you soon! 🌿');
}

// ══════════════════════════════════
//  MARKETPLACE
// ══════════════════════════════════
let marketFilter = 'all';
let marketSearch = '';

function renderMarket(data) {
  const grid = document.getElementById('market-grid');
  const src = data || listings;
  const filtered = src.filter(l => {
    const searchMatch = !marketSearch || l.title.toLowerCase().includes(marketSearch.toLowerCase()) || l.type.toLowerCase().includes(marketSearch.toLowerCase());
    const filterMatch = marketFilter === 'all' || (marketFilter === 'trade' && l.trade) || l.type === marketFilter;
    return searchMatch && filterMatch;
  });
  grid.innerHTML = filtered.map(l => `
    <div class="plant-card" onclick="openListing(${l.id})">
      <div class="pc-img ${l.imgClass}">
        <div class="pc-badge ${l.trade ? 'pc-trade' : ''}">${l.free ? '🎁 Free' : l.trade ? '🔄 Trade' : l.type}</div>
        ${l.emoji}
      </div>
      <div class="pc-body">
        <div class="pc-title">${l.title}</div>
        <div class="pc-seller">🧑 ${l.seller} · ${l.hood}</div>
        <div class="pc-footer">
          <div class="pc-price">${l.free ? 'Free' : l.trade ? 'Trade Only' : '$' + l.price}</div>
          <div class="pc-loc">📍 ${l.loc}</div>
        </div>
      </div>
    </div>
  `).join('');
  if (!filtered.length) grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--text3);">No listings found. Try a different filter!</div>';
}

function setMarketFilter(f, el) {
  marketFilter = f;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderMarket();
}

function filterMarket() {
  marketSearch = document.getElementById('market-search').value;
  renderMarket();
}

function openListing(id) {
  const l = listings.find(x => x.id === id);
  if (!l) return;
  const modal = document.getElementById('listing-modal');
  const content = document.getElementById('modal-content');
  content.innerHTML = `
    <div class="modal-img ${l.imgClass}" style="font-size:5rem;">${l.emoji}</div>
    <div class="modal-body">
      <div class="modal-title">${l.title}</div>
      <div class="modal-price">${l.free ? '🎁 Free — Giving Away' : l.trade ? '🔄 Trade Only' : '$' + l.price}</div>
      <div class="modal-meta">
        <div class="modal-meta-item">🏷️ ${l.type}</div>
        <div class="modal-meta-item">📍 ${l.loc}, ${l.hood}</div>
        <div class="modal-meta-item">💳 ${l.venmo}</div>
      </div>
      <div class="modal-desc">${l.desc}</div>
      <div class="modal-seller">
        <div class="seller-av" style="font-size:1.5rem;">${l.sellerEmoji}</div>
        <div>
          <div class="seller-name">${l.seller}</div>
          <div class="seller-loc">${l.hood} · Bay Area</div>
          <div class="seller-rating">${l.rating} (${l.reviews} reviews)</div>
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-green" style="flex:1;justify-content:center;" onclick="contactSeller(${l.id})">💬 Message Seller</button>
        <button class="btn btn-outline" onclick="closeListingModal()">Close</button>
      </div>
    </div>
  `;
  modal.classList.add('open');
}

function closeModal(e) { if (e.target === document.getElementById('listing-modal')) closeListingModal(); }
function closeListingModal() { document.getElementById('listing-modal').classList.remove('open'); }

function contactSeller(listingId) {
  closeListingModal();
  showView('messages', document.getElementById('anav-messages'));
  const l = listings.find(x => x.id === listingId);
  toast(`Opening chat about "${l.title}" 💬`);
  setTimeout(() => openChat(1), 300);
}

// ══════════════════════════════════
//  SELL
// ══════════════════════════════════
function selectType(el, type) {
  selectedType = type;
  document.querySelectorAll('.type-opt').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function setPriceMode(mode, el) {
  priceMode = mode;
  document.querySelectorAll('.ptoggle').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('price-field').style.display = mode === 'sell' ? 'block' : 'none';
}

function submitListing() {
  const title = document.getElementById('sell-title').value.trim();
  if (!title) { toast('Please add a listing title! 🌱'); return; }
  document.getElementById('sell-form-area').style.display = 'none';
  document.getElementById('sell-success').style.display = 'block';
  // Add to my listings
  myListings.unshift({ title, type: selectedType, emoji: '🌱', imgBg: 'pc-img-3', price: priceMode === 'sell' ? '$' + (document.getElementById('sell-price').value || '?') : priceMode === 'trade' ? 'Trade' : 'Free', status: 'avail' });
  document.getElementById('ds-listings').textContent = myListings.filter(l => l.status === 'avail').length;
  renderMyListings();
}

function resetSellForm() {
  document.getElementById('sell-form-area').style.display = 'block';
  document.getElementById('sell-success').style.display = 'none';
  document.getElementById('sell-title').value = '';
  document.getElementById('sell-price').value = '';
  document.getElementById('sell-desc').value = '';
}

// ══════════════════════════════════
//  COMMUNITY
// ══════════════════════════════════
function renderCommunity() {
  const container = document.getElementById('comm-posts');
  container.innerHTML = commPosts.map(p => `
    <div class="post-card">
      <div class="post-head">
        <div class="post-av ${p.avCls}" style="font-size:1.2rem;">${p.emoji}</div>
        <div>
          <div class="post-author-name">${p.author}</div>
          <div class="post-time">${p.time}</div>
        </div>
      </div>
      <div class="post-title">${p.title}</div>
      <div class="post-content">${p.content}</div>
      <div class="post-tags">${p.tags.map(t => `<span class="comm-tag">${t}</span>`).join('')}</div>
      <div class="post-actions">
        <div class="pact ${p.liked ? 'liked' : ''}" onclick="likePost(${p.id}, this)">❤️ ${p.likes}</div>
        <div class="pact">💬 ${p.comments} comments</div>
        <div class="pact">↗️ Share</div>
      </div>
    </div>
  `).join('');
}

function likePost(id, el) {
  const post = commPosts.find(p => p.id === id);
  if (post) {
    post.liked = !post.liked;
    post.likes += post.liked ? 1 : -1;
    el.classList.toggle('liked');
    el.innerHTML = '❤️ ' + post.likes;
  }
}

function submitPost() {
  const text = document.getElementById('new-post-text').value.trim();
  if (!text) { toast('Write something first! 🌱'); return; }
  commPosts.unshift({ id: Date.now(), author: currentUser.firstName + ' (you)', avCls: 'post-av-g', emoji: '🧑', title: text.substring(0,60) + (text.length > 60 ? '…' : ''), content: text, tags: ['#community'], likes: 0, comments: 0, time: 'Just now', liked: false });
  document.getElementById('new-post-text').value = '';
  renderCommunity();
  toast('Post published! 🌿');
}

function appendTag(tag) {
  const ta = document.getElementById('new-post-text');
  ta.value += (ta.value ? ' ' : '') + tag;
  ta.focus();
}

// ══════════════════════════════════
//  MESSAGES
// ══════════════════════════════════
function renderMessages() {
  const list = document.getElementById('msg-conv-list');
  list.innerHTML = convos.map(c => `
    <div class="msg-conv ${activeChatId === c.id ? 'active' : ''}" onclick="openChat(${c.id})">
      <div class="conv-av" style="font-size:1.3rem;">${c.emoji}${c.online ? '<div class="conv-online"></div>' : ''}</div>
      <div class="conv-info">
        <div class="conv-name">${c.name}</div>
        <div class="conv-preview">Re: ${c.listing}</div>
      </div>
      <div class="conv-meta">
        <div class="conv-time">${c.time}</div>
        ${c.unread ? `<div class="conv-badge">${c.unread}</div>` : ''}
      </div>
    </div>
  `).join('');
}

function openChat(id) {
  activeChatId = id;
  const c = convos.find(x => x.id === id);
  c.unread = 0;
  renderMessages();
  const panel = document.getElementById('chat-panel');
  panel.innerHTML = `
    <div class="chat-header">
      <div class="conv-av" style="font-size:1.3rem;width:44px;height:44px;background:var(--cream2);border-radius:50%;display:flex;align-items:center;justify-content:center;">${c.emoji}</div>
      <div class="chat-header-info">
        <div class="chat-hname">${c.name}</div>
        <div class="chat-hlisting">Re: ${c.listing}</div>
        <div class="chat-hstatus">${c.online ? '● Online' : '● Last seen recently'}</div>
      </div>
    </div>
    <div class="chat-messages" id="chat-msgs-${id}"></div>
    <div class="chat-input-bar">
      <div class="chat-input-wrap">
        <textarea class="chat-ta" id="chat-input-${id}" placeholder="Message ${c.name}…" rows="1" onkeydown="handleChatKey(event,${id})"></textarea>
      </div>
      <button class="send-btn" onclick="sendMsg(${id})">➤</button>
    </div>
  `;
  renderChatMessages(id);
  document.getElementById('msg-badge').style.display = 'none';
}

function renderChatMessages(id) {
  const c = convos.find(x => x.id === id);
  const container = document.getElementById('chat-msgs-' + id);
  if (!container) return;
  container.innerHTML = `<div class="date-divider">Today</div>` + c.messages.map(m => `
    <div class="msg-wrap ${m.from === 'me' ? 'me' : 'them'}">
      ${m.from !== 'me' ? `<div style="width:30px;height:30px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.9rem;flex-shrink:0;">${convos.find(x=>x.id===id).emoji}</div>` : ''}
      <div>
        <div class="msg-time-text">${m.time}</div>
        <div class="msg-bubble">${m.text}</div>
      </div>
    </div>
  `).join('');
  container.scrollTop = container.scrollHeight;
}

function sendMsg(id) {
  const input = document.getElementById('chat-input-' + id);
  const text = input.value.trim();
  if (!text) return;
  const c = convos.find(x => x.id === id);
  c.messages.push({ from:'me', text, time:'Just now' });
  input.value = '';
  renderChatMessages(id);
  // Simulate reply
  setTimeout(() => {
    const replies = ['Sounds great! 🌱', 'Perfect, I\'ll be there!', 'Can we meet at 3pm?', 'Thanks so much 😊', 'I love this idea! Let me check my schedule.'];
    c.messages.push({ from:'them', text: replies[Math.floor(Math.random()*replies.length)], time:'Just now' });
    renderChatMessages(id);
  }, 1200);
}

function handleChatKey(e, id) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(id); }
}

// ══════════════════════════════════
//  DASHBOARD
// ══════════════════════════════════
function renderDashboard() {
  renderMyListings();
}

function renderMyListings() {
  const container = document.getElementById('my-listings-list');
  if (!container) return;
  container.innerHTML = myListings.map(l => `
    <div class="my-listing-row">
      <div class="ml-img ${l.imgBg}">${l.emoji}</div>
      <div class="ml-info">
        <div class="ml-name">${l.title}</div>
        <div class="ml-price">${l.price} · ${l.type}</div>
      </div>
      <div class="ml-status status-${l.status}">${l.status === 'avail' ? 'Available' : l.status === 'sold' ? 'Sold' : 'Reserved'}</div>
    </div>
  `).join('');
}

// ══════════════════════════════════
//  TOAST
// ══════════════════════════════════
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

function scrollToSection(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth' });
}

// ── INIT ──
renderMarket();
</script>
